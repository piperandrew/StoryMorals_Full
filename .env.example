# Copy to `.env` and fill in your keys, OR export these in your shell instead.
# `.env` is git-ignored so keys never get committed. The scripts read these at
# runtime — nothing is hard-coded or written to disk.

# Required for OpenAI (gpt* / o1* / o3*) models.
OPENAI_API_KEY=

# Required when a gemini-* model is used (either GEMINI_API_KEY or GOOGLE_API_KEY).
GEMINI_API_KEY=
